COMPOSE_PROJECT_NAME=community-prod

# Database (MariaDB)
MYSQL_ROOT_PASSWORD=1111
MYSQL_DATABASE=community
MYSQL_USER=community
MYSQL_PASSWORD=community_pwd
MYSQL_PORT=3306

# Backend
APP_JWT_SECRET=change-this-community-jwt-secret-64-or-more-chars
APP_JWT_EXPIRATION_MS=86400000
APP_ALLOWED_ORIGINS=http://localhost

# Reverse Proxy / Domain
DOMAIN_NAME=localhost
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443
ENABLE_HTTPS=false
LETSENCRYPT_ENABLED=false
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=false
LETSENCRYPT_RENEW_INTERVAL_HOURS=12
LETSENCRYPT_LOG_FORMAT=json
SSL_CERT_DIR=./nginx/ssl
SSL_CERT_PATH=/etc/nginx/certs/fullchain.pem
SSL_KEY_PATH=/etc/nginx/certs/privkey.pem

# Frontend
VITE_API_BASE_URL=http://localhost/api
